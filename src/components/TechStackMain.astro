---
import Card from "./Card.astro";
import IconTooltip from "./IconTooltip.astro";

const iconClass = "svgRotate mx-2 my-1 h-10 w-10 sm:mx-4 sm:my-0";
---

<>
  <h1 class="text-center text-4xl font-bold leading-none tracking-tight">
    My Tech Stack
  </h1>
  <div class="relative mt-8 flex items-center justify-center">
    <div class="mx-auto h-[480px] w-[1px] border border-neutral-border"></div>
    <div
      class="absolute mx-auto h-[1px] w-full max-w-[1130px] border border-neutral-border"
    >
    </div>
    <div class="absolute mx-auto grid w-full max-w-[1130px] grid-cols-2">
      <div class="flex h-[200px] w-full items-center justify-center">
        <Card
          cardFooter="frontend"
          cardWidth="w-[150px] sm:w-[240px] xl:w-[480px]"
        >
          <div class="mx-auto grid grid-cols-2 justify-center sm:flex">
            <IconTooltip name="react" label="React" class={iconClass} />
            <IconTooltip name="remix" label="Remix" class={iconClass} />
            <IconTooltip
              name="astro_logo_figma"
              label="Astro"
              class={iconClass}
            />
            <IconTooltip
              name="tailwind"
              label="Tailwind CSS"
              class={iconClass}
            />
          </div>
        </Card>
      </div>
      <div class="flex h-[200px] w-full items-center justify-center">
        <Card
          cardFooter="backend"
          cardWidth="w-[150px] sm:w-[240px] xl:w-[480px]"
        >
          <div class="mx-auto grid grid-cols-2 justify-center sm:flex">
            <IconTooltip name="nodejs" label="Node.js" class={iconClass} />
            <IconTooltip name="mongodb" label="MongoDB" class={iconClass} />
            <IconTooltip name="mysql" label="MySQL" class={iconClass} />
          </div>
        </Card>
      </div>
      <div class="flex h-[200px] w-full items-center justify-center">
        <Card
          cardFooter="deployment & CI/CD"
          cardWidth="w-[150px] sm:w-[240px] xl:w-[480px]"
        >
          <div class="mx-auto grid grid-cols-2 justify-center sm:flex">
            <IconTooltip name="gitlab" label="GitLab" class={iconClass} />
            <IconTooltip name="railway" label="Railway" class={iconClass} />
            <IconTooltip
              name="github-mark-white"
              label="GitHub"
              class={iconClass}
            />
            <IconTooltip name="vercel" label="Vercel" class={iconClass} />
          </div>
        </Card>
      </div>
      <div class="flex h-[200px] w-full items-center justify-center">
        <Card cardWidth="w-[150px] sm:w-[240px] xl:w-[480px]">
          <div class="mx-auto grid grid-cols-2 justify-center sm:flex">
            <IconTooltip name="obsidian" label="Obsidian" class={iconClass} />
            <IconTooltip name="notion" label="Notion" class={iconClass} />
            <IconTooltip
              name="excalidraw"
              label="Excalidraw"
              class={iconClass}
            />
          </div>
          <h1
            class="mt-4 text-center text-lg font-semibold tracking-tight"
            slot="footer"
          >
            notes & ideation{" "}
            <span
              class="inline-block"
              style="filter: drop-shadow(0 0 12px rgba(234, 179, 8, 0.8)) drop-shadow(0 0 20px rgba(234, 179, 8, 0.5)); text-shadow: 0 0 8px rgba(234, 179, 8, 0.6)"
            >
              💡
            </span>
          </h1>
        </Card>
      </div>
    </div>
  </div>
</>
