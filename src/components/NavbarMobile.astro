---
import { Icon } from "astro-icon/components";

const currentPath = Astro.url.pathname;

const routes = [
  { href: "/", icon: "nav-home", label: "Home" },
  { href: "/blogs", icon: "nav-blogs", label: "Blogs" },
  { href: "/work", icon: "nav-projects", label: "Work" },
  {
    href: "/recommendations",
    icon: "nav-recommendations",
    label: "Recommendations",
  },
  { href: "/talks", icon: "nav-talks", label: "Talks" },
];
---

<nav
  class="fixed bottom-4 left-1/2 z-50 -translate-x-1/2 rounded-full bg-neutral/60 px-3 py-2 ring-2 ring-neutral-border backdrop-blur-lg"
  aria-label="Mobile navigation"
>
  <ul class="flex items-center gap-1">
    {
      routes.map(({ href, icon, label }) => {
        const isActive =
          currentPath === href ||
          (href !== "/" && currentPath.startsWith(href));
        return (
          <li>
            <a
              href={href}
              aria-label={label}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "flex h-11 w-11 items-center justify-center rounded-full transition-colors duration-200",
                isActive
                  ? "text-color-yellow"
                  : "text-neutral-400 hover:text-white",
              ]}
            >
              <Icon name={icon} class="h-5 w-5" />
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
