---
import "../../base.css";
import BaseLayout from "../layout/BaseLayout.astro";
import Pill from "../components/Pill.astro";
import IconTooltip from "../components/IconTooltip.astro";
import ArrowIcon from "../components/ArrowIcon.astro";
import { projectsSEO } from "../utils/seoConfigs";
import { projects, ossPRs } from "../utils/projectsData";
---

<BaseLayout seo={projectsSEO}>
  <section
    class="flex flex-col items-center justify-center px-8 pb-12 pt-40 text-center md:pb-8 md:pt-20 2xl:px-32"
  >
    <h1 class="text-5xl font-semibold leading-tight tracking-tight">Work</h1>
    <p class="mt-7 max-w-2xl text-lg font-medium leading-relaxed">
      Projects I've built and open source contributions.
    </p>
  </section>
  <div class="mx-auto w-full max-w-[860px] px-8 pb-20 2xl:px-32">
    <section>
      <p
        class="text-neutral-500 mb-3 text-base font-bold uppercase tracking-[0.08em]"
      >
        Projects
      </p>
      <div class="stagger-fade-up flex flex-col gap-4">
        {
          projects.map((p) => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start gap-3.5 rounded-xl bg-neutral px-5 py-5 ring-1 ring-neutral-border ring-offset-black transition duration-300 hover:shadow-glow-yellow hover:outline-none hover:ring-2 hover:ring-color-yellow hover:ring-offset-4"
            >
              <div class="min-w-0 flex-1">
                <p class="mb-1 text-lg font-semibold text-white">{p.name}</p>
                <p class="text-neutral-500 mb-2 text-sm leading-relaxed">
                  {p.description}
                </p>
                <div class="flex flex-wrap items-center gap-3">
                  {p.tech.map((item) => (
                    <IconTooltip
                      name={item.icon}
                      label={item.label}
                      class="h-5 w-5 text-neutral-400"
                    />
                  ))}
                </div>
              </div>
              <div class="flex shrink-0 items-center gap-2.5">
                <span class="text-neutral-500 text-xs">{p.year}</span>
                <ArrowIcon class="mt-0.5 text-color-yellow" />
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <div class="bg-neutral-800 my-8 h-px"></div>

    <section>
      <p
        class="text-neutral-500 mb-3 text-base font-bold uppercase tracking-[0.08em]"
      >
        OSS Contributions
      </p>
      <div class="stagger-fade-up flex flex-col gap-4">
        {
          ossPRs.map((pr) => (
            <a
              href={pr.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start gap-3.5 rounded-xl bg-neutral px-5 py-5 ring-1 ring-neutral-border ring-offset-black transition duration-300 hover:shadow-glow-yellow hover:outline-none hover:ring-2 hover:ring-color-yellow hover:ring-offset-4"
            >
              <Pill variant="accent" bold class="mt-0.5 shrink-0">
                PR #{pr.number}
              </Pill>
              <div class="min-w-0 flex-1">
                <p class="mb-1 text-lg font-semibold text-white">{pr.title}</p>
                <div class="text-neutral-500 flex flex-wrap items-center gap-2.5 text-xs">
                  <Pill variant="success" bold>
                    merged
                  </Pill>
                  <span class="text-neutral-500 text-xs">{pr.repo}</span>
                  <span class="text-neutral-500 text-xs">{pr.date}</span>
                </div>
              </div>
              <ArrowIcon class="mt-1 shrink-0 text-color-yellow" />
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
