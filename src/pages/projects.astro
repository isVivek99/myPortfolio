---
import "../../base.css";
import BaseLayout from "../layout/BaseLayout.astro";
import Pill from "../components/Pill.astro";
import IconTooltip from "../components/IconTooltip.astro";
import ArrowIcon from "../components/ArrowIcon.astro";
import { projectsSEO } from "../utils/seoConfigs";
import { projects, ossPRs, currentStatus } from "../utils/projectsData";
---

<BaseLayout seo={projectsSEO}>
  <section
    class="flex flex-col items-center justify-center px-8 pb-8 pt-12 text-center md:pb-8 md:pt-20 2xl:px-32"
  >
    <h1 class="text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">
      Work
    </h1>
    <p class="mt-7 max-w-2xl text-base font-medium leading-relaxed sm:text-lg">
      Projects I've built and open source contributions.
    </p>
  </section>
  <div class="mx-auto w-full max-w-[860px] px-8 pb-20 2xl:px-32">
    <div class="mb-9 flex items-center justify-center gap-2.5">
      <span class="relative flex h-2 w-2">
        <span
          class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"
        ></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-green-400"
        ></span>
      </span>
      <span class="text-neutral-400 text-xs">
        Currently working on:
        {
          currentStatus.href ? (
            <a
              href={currentStatus.href}
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-color-yellow underline-offset-4 hover:underline"
            >
              {currentStatus.text}
            </a>
          ) : (
            <span class="font-semibold text-color-yellow">
              {currentStatus.text}
            </span>
          )
        }
      </span>
    </div>

    <section>
      <p
        class="text-neutral-500 mb-3 text-sm font-bold uppercase tracking-[0.08em] sm:text-base"
      >
        Projects
      </p>
      <div class="stagger-fade-up flex flex-col gap-4">
        {
          projects.map((p) => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start gap-3.5 rounded-xl bg-neutral px-5 py-5 ring-1 ring-neutral-border ring-offset-black transition duration-300 hover:shadow-glow-yellow hover:outline-none hover:ring-2 hover:ring-color-yellow hover:ring-offset-4"
            >
              <div class="min-w-0 flex-1">
                <p class="mb-1 text-base font-semibold text-white sm:text-lg">{p.name}</p>
                <p class="text-neutral-500 mb-2 text-sm leading-relaxed">
                  {p.description}
                </p>
                <div class="flex flex-wrap items-center gap-3">
                  {p.tech.map((item) => (
                    <IconTooltip
                      name={item.icon}
                      label={item.label}
                      class="h-5 w-5 text-neutral-400"
                    />
                  ))}
                </div>
              </div>
              <div class="flex shrink-0 items-center gap-2.5">
                <span class="text-neutral-500 hidden text-xs sm:inline">
                  {p.year}
                </span>
                <ArrowIcon class="mt-0.5 text-color-yellow" />
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <div class="bg-neutral-800 my-8 h-px"></div>

    <section>
      <p
        class="text-neutral-500 mb-3 text-sm font-bold uppercase tracking-[0.08em] sm:text-base"
      >
        OSS Contributions
      </p>
      <div class="stagger-fade-up flex flex-col gap-4">
        {
          ossPRs.map((pr) => (
            <a
              href={pr.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative flex flex-col gap-2.5 rounded-xl bg-neutral px-5 py-5 ring-1 ring-neutral-border ring-offset-black transition duration-300 hover:shadow-glow-yellow hover:outline-none hover:ring-2 hover:ring-color-yellow hover:ring-offset-4 sm:flex-row sm:items-start sm:gap-3.5"
            >
              <Pill variant="accent" bold class="w-fit shrink-0 sm:mt-0.5">
                PR #{pr.number}
              </Pill>
              <div class="min-w-0 flex-1">
                <p class="mb-1 pr-7 text-base font-semibold text-white sm:pr-0 sm:text-lg">
                  {pr.title}
                </p>
                <div class="text-neutral-500 flex flex-wrap items-center gap-2.5 text-xs">
                  <Pill variant="success" bold>
                    merged
                  </Pill>
                  <span class="text-neutral-500 text-xs">{pr.repo}</span>
                  <span class="text-neutral-500 text-xs">{pr.date}</span>
                </div>
              </div>
              <ArrowIcon class="absolute right-5 top-5 shrink-0 text-color-yellow sm:static sm:mt-1" />
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
