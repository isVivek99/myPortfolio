    */}

    <div class="bg-neutral-800 my-8 h-px"></div>

    <section>
      <p
        class="text-neutral-500 mb-3 text-base font-bold uppercase tracking-[0.08em]"
      >
        Video Recommendations
      </p>
      <div class="flex flex-col gap-4">
        {
          videoRecommendations.map((v) => {
            const Wrapper = v.url ? "a" : "div";
            const wrapperProps = v.url
              ? {
                  href: v.url,
                  target: "_blank",
                  rel: "noopener noreferrer",
                  class:
                    "ring-neutral-border ring-offset-black hover:ring-color-yellow hover:shadow-glow-accent group flex items-start gap-3.5 rounded-xl bg-neutral px-5 py-5 ring-1 transition duration-300 hover:outline-none hover:ring-2 hover:ring-offset-4",
                }
              : {
                  class:
                    "ring-neutral-border flex items-start gap-3.5 rounded-xl bg-neutral px-5 py-5 ring-1",
                };
            return (
              <Wrapper {...wrapperProps}>
                <div class="min-w-0 flex-1">
                  <p class="mb-0.5 text-lg font-semibold text-white">
                    {v.title}
                  </p>
                  <p class="text-neutral-500 text-sm">{v.creator}</p>
                  {v.why && (
                    <p class="text-neutral-500 mt-1.5 text-sm leading-relaxed">
                      {v.why}
                    </p>
                  )}
                </div>
                {v.url && <ArrowIcon class="mt-1 shrink-0 text-color-yellow" />}
              </Wrapper>
            );
          })
        }
      </div>
    </section>
  </div>
</BaseLayout>
