                  {b.why && (
                    <p class="text-neutral-500 mt-1.5 text-sm leading-relaxed">
                      {b.why}
                    </p>
                  )}
                </div>
                {b.url && <ArrowIcon class="mt-1 shrink-0 text-color-yellow" />}
