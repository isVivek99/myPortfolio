---
// src/pages/blog/[slug].astro
import "../../../base.css";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";
import BaseLayout from "../../layout/BaseLayout.astro";
import TOC from "../../components/blogs/TOC.astro";
import RelatedPosts from "../../components/blogs/RelatedPosts.astro";
import myGradient from "../../icons/myGradient.jpeg";
import { formatDate } from "../../utils/UTCDateStringToReadable";
import myImageTwo from "../../icons/myImage-2.jpg";
import { generateBlogSEO } from "../../utils/seoConfigs";

const { slug } = Astro.params;
const post = await getEntry("blogs", slug);

if (!post) {
  throw new Error("Blog post not found for this slug.");
}

const { Content, headings } = await post.render();

const blogSEO = generateBlogSEO({
  title: post.data.title,
  subheading: post.data.subheading,
  publishedAt: post.data.publishedAt,
  tags: post.data.tags,
  slug: post.slug,
  description: post.data.description,
  keywords: post.data.keywords,
});
---

<BaseLayout seo={blogSEO}>
  <section
    class="section-1 relative min-h-screen w-full snap-start overflow-x-clip pt-20 md:min-h-fit md:pt-32"
  >
    <a
      href="/blogs"
      aria-label="Back to blogs"
      class="text-neutral-400 absolute left-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-neutral/80 ring-1 ring-neutral-border backdrop-blur transition-colors duration-200 hover:text-white md:hidden"
    >
      <Icon name="nav-back" class="h-5 w-5" />
    </a>

    <div class="mb-4 h-48 w-auto">
      <Image
        src={myGradient}
        height={100}
        width={100}
        alt=""
        class="m h-full w-full rounded-t-xl mix-blend-soft-light"
      />

      <Image
        src={post.data.cover}
        height={100}
        width={100}
        alt={post.data.coverAlt ?? post.data.title}
        class="absolute top-20 h-48 w-full rounded-t-xl"
        loading={"lazy"}
      />
    </div>

    <div class="container mx-auto max-w-6xl px-4">
      <!-- Title block: full container width so it centers relative to page, not column -->
      <div class="mx-auto max-w-4xl">
        <h1
          class="mb-6 text-center text-3xl font-bold leading-tight tracking-tight sm:mb-8 sm:text-5xl sm:leading-none lg:text-header xl:mt-0"
        >
          {post.data.title}
        </h1>
        <h2
          class="mb-8 text-center text-lg font-bold leading-snug tracking-tight text-opacity-60 opacity-60 sm:text-xl sm:leading-tight lg:text-subheader xl:mt-0"
        >
          {post.data.subheading}
        </h2>
        <div
          class="mx-auto mb-12 mt-4 flex max-w-md flex-col items-center gap-3 sm:flex-row sm:justify-between sm:gap-0"
        >
          <div class="flex items-center gap-3 sm:gap-0">
            <Image
              src={myImageTwo}
              height={100}
              width={100}
              alt="Vivek Lokhande"
              loading={"lazy"}
              class="h-10 w-10 rounded-3xl sm:mr-3"
            />
            <p class="font-bold">Vivek Lokhande</p>
          </div>
          <p class="text-sm font-bold text-neutral-border sm:text-base">
            {formatDate(post.data.publishedAt.toLocaleDateString())} — {
              post.data.readingTimeInMins
            } min read
          </p>
        </div>
      </div>

      <!-- Article body + TOC grid -->
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-4">
        <div class="lg:col-span-3">
          <article
            class="prose prose-lg prose-invert mx-auto mb-16 text-white prose-headings:font-bold prose-h2:text-2xl prose-h3:text-xl prose-a:text-blue-400 prose-a:underline hover:prose-a:text-blue-300 prose-code:rounded-md prose-code:bg-gray-800 prose-code:p-1 prose-code:text-white prose-img:rounded-xl"
          >
            <Content />
          </article>
          <RelatedPosts
            currentSlug={post.slug}
            tags={post.data.tags}
            limit={3}
          />
        </div>

        <!-- Table of Contents Sidebar -->
        <div class="hidden lg:col-span-1 lg:block">
          <div class="sticky top-24">
            <TOC headings={headings} levels={3} />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
